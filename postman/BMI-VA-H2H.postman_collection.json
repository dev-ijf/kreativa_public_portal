    {
      "name": "Production (JWT HS256)",
      "description": "Body = JWT HS256 (text/plain), respons = JWT HS256. Pre-request script auto-sign, Test script auto-decode response.",
      "item": [
        {
          "name": "1. Sign On",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const CryptoJS = require('crypto-js');",
                  "function b64url(wordArr) { return CryptoJS.enc.Base64.stringify(wordArr).replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=+$/,''); }",
                  "function signJwt(p, s) {",
                  "  var h = b64url(CryptoJS.enc.Utf8.parse(JSON.stringify({alg:'HS256',typ:'JWT'})));",
                  "  var b = b64url(CryptoJS.enc.Utf8.parse(JSON.stringify(p)));",
                  "  var d = h+'.'+b;",
                  "  return d+'.'+b64url(CryptoJS.HmacSHA256(d,s));",
                  "}",
                  "var jwt = signJwt({",
                  "  SIGNONINFO: pm.collectionVariables.get('TRXDATE')+';bankmuamalatindonesia',",
                  "  METHOD:'SIGNON',",
                  "  USERNAME:pm.collectionVariables.get('USERNAME_BMI'),",
                  "  PASSWORD:pm.collectionVariables.get('PASSWORD_BMI')",
                  "}, pm.collectionVariables.get('JWT_SECRET'));",
                  "pm.variables.set('JWT_BODY', jwt);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  var parts = pm.response.text().split('.');",
                  "  if(parts.length===3){",
                  "    var payload = JSON.parse(atob(parts[1].replace(/-/g,'+').replace(/_/g,'/')));",
                  "    console.log('Decoded response:', JSON.stringify(payload,null,2));",
                  "    pm.visualizer.set('<pre>'+JSON.stringify(payload,null,2)+'</pre>');",
                  "  }",
                  "} catch(e){ console.log('Not JWT or decode error:', e.message); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/plain; charset=ISO-8859-1" }],
            "body": { "mode": "raw", "raw": "{{JWT_BODY}}", "options": { "raw": { "language": "text" } } },
            "url": "{{BASE_URL}}/api/va/signon"
          }
        },
