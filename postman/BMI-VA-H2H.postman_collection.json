              "  return data + '.' + sig;",
              "}",
              "const secret = pm.collectionVariables.get('JWT_SECRET');",
              "const payload = {",
              "  CCY: '360',",
              "  VANO: pm.collectionVariables.get('VANO'),",
              "  TRXDATE: pm.collectionVariables.get('TRXDATE'),",
              "  METHOD: 'INQUIRY',",
              "  USERNAME: pm.collectionVariables.get('USERNAME_BMI'),",
              "  PASSWORD: pm.collectionVariables.get('PASSWORD_BMI'),",
              "  CHANNELID: '1',",
              "  REFNO: pm.collectionVariables.get('REFNO')",
              "};",
              "pm.collectionVariables.set('BMI_JWT_BODY', signJwt(payload, secret));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "text/plain; charset=ISO-8859-1" }],
        "body": { "mode": "raw", "raw": "{{BMI_JWT_BODY}}", "options": { "raw": { "language": "text" } } },
        "url": "{{BASE_URL}}/api/va/inquiry"
      }
    },
